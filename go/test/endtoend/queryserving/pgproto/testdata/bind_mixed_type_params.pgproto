#
# Bind carrying four text-format parameter values of distinct types.
#
# Companion to bind_text_params.pgproto: a single Bind whose parameters span
# several type categories (int, text, bool, numeric), all sent in text format,
# so the parameter-count and per-parameter length/value framing is exercised
# beyond the homogeneous case. PostgreSQL casts each bound value and returns one
# DataRow; the multigateway must relay the same trace.
#
# Bind field layout (tab-separated):
#   'B'  portal  stmt  ncodes  nparams  [paramlen "value"]...  nresultcodes
# Each paramlen is the byte length of the following value: "42"=2, "hello"=5,
# "t"=1, "3.14"=4.
#

'P'	""	"SELECT $1::int, $2::text, $3::bool, $4::numeric"	0
'B'	""	""	0	4	2	"42"	5	"hello"	1	"t"	4	"3.14"	0
'D'	'P'	""
'E'	""	0
'S'
'Y'
'X'
