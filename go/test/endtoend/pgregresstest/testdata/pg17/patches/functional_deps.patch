# Known divergence: multigateway manages SQL-level PREPARE/EXECUTE, so an error
# raised while running `EXECUTE foo` is reported with a "LINE 1: EXECUTE foo;\n ^"
# source cursor that stock PostgreSQL omits for the EXECUTE statement.
--- a
+++ b
@@ -230,3 +230,5 @@
 ALTER TABLE articles DROP CONSTRAINT articles_pkey RESTRICT;
 EXECUTE foo; -- fail
 ERROR: column "articles.keywords" must appear in the GROUP BY clause or be used in an aggregate function
+LINE 1: EXECUTE foo;
+^
