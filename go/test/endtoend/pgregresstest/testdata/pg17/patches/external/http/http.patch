# Known divergence: the statement_timeout cancellation message. Upstream's
# expected file says "canceling statement due to user request" — in pgsql-http
# the cancel lands inside libcurl's wait loop and is re-raised by the
# extension's interrupt handling as a generic cancel. Through multigres the
# suite's `SET statement_timeout = 200` is applied on the backend pinned by the
# preceding temporary table, whose own timeout timer fires first and raises
# PostgreSQL's standard "canceling statement due to statement timeout". The
# semantics the test verifies are identical and verified: the statement aborts
# after ~200 ms (the following `m` row pins the elapsed time) and the session —
# including the temp table, kept by the gateway's reserved connection across the
# cancellation — survives. Only the message wording differs.
--- a
+++ b
@@ -307,7 +307,7 @@
 SELECT now() AS start;
 SELECT *
 FROM http_get(current_setting('http.server_host') || '/delay/7');
-ERROR: canceling statement due to user request
+ERROR: canceling statement due to statement timeout
 SELECT round(extract(epoch FROM now() - start) * 10) AS m
 FROM timer;
 m
