# Known divergence: multigateway rejects LOAD by design (loading shared
# libraries through the connection pooler is not permitted; see
# go/services/multigateway/planner/unsafe_stmt.go). The library is preloaded
# cluster-wide instead via shared_preload_libraries (PreloadLibraries on the
# plpgsql_check spec in extensions.go), so the test's LOAD is semantically a
# no-op and only the extra ERROR line differs.
--- a
+++ b
@@ -1,4 +1,5 @@
 LOAD 'plpgsql';
+ERROR: LOAD is not supported: loading shared libraries is not permitted through the connection pooler
 CREATE EXTENSION IF NOT EXISTS plpgsql_check;
 NOTICE: extension "plpgsql_check" already exists, skipping
 set client_min_messages to notice;
