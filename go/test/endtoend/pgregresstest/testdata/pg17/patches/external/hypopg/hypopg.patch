# Known partial-coverage divergence: HypoPG's hypothetical indexes live in
# backend-local memory. In stock PostgreSQL, pg_regress runs this test on one
# backend, so a later EXPLAIN and hypopg() call see the hypothetical index
# created earlier in the same autocommit script. Through multigateway's
# transaction pool, separate autocommit statements may use different pooled
# backends, so those later statements can land on a backend that never saw the
# hypopg_create_index() call.
#
# This patch documents the current drop-in compatibility gap until the gateway
# can automatically pin sessions after observing HypoPG state-creating functions.
--- a
+++ b
@@ -125,15 +125,14 @@
 WHERE e ~ 'Index.*<\d+>btree_hypo.*';
 count
 -------
-1
+0
 (1 row)

 -- Remove one hypothetical index
 SELECT hypopg_drop_index(indexrelid) FROM hypopg() ORDER BY indexrelid LIMIT 1;
 hypopg_drop_index
 -------------------
-t
-(1 row)
+(0 rows)

 -- Remove all the hypothetical indexes
 SELECT hypopg_reset();
