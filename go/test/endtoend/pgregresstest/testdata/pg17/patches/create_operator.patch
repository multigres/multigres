# Known divergence (by design): this statement is rejected by multigateway's
# own SQL parser before it reaches PostgreSQL, so the error wording differs --
# "parse error at position 18: syntax error" instead of PostgreSQL's
# "syntax error at or near <tok>" with the "LINE n: ...\n  ^" source cursor.
# Here: CREATE OPERATOR => (...).
--- a
+++ b
@@ -43,9 +43,7 @@
 rightarg = int8,
 procedure = factorial
 );
-ERROR: syntax error at or near "=>"
-LINE 1: CREATE OPERATOR => (
-^
+ERROR: parse error at position 18: syntax error
 -- lexing of <=, >=, <>, != has a number of edge cases
 -- (=> is tested elsewhere)
 -- this is legal because ! is not allowed in sql ops
@@ -61,9 +59,7 @@
 
 -- postfix operators don't work anymore
 SELECT 10 !=-;
-ERROR: syntax error at or near ";"
-LINE 1: SELECT 10 !=-;
-^
+ERROR: parse error at position 14: syntax error
 -- make sure lexer returns != as <> even in edge cases
 SELECT 2 !=/**/ 1, 2 !=/**/ 2;
 ?column? | ?column?
