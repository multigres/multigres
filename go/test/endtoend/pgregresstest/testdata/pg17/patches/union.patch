# Known divergence (cosmetic): multigateway rewrites the query before it reaches
# PostgreSQL, so the error-cursor position shifts while the error itself is
# identical. multigateway drops the "LINE n: ...\n  ^" source-position context from the error.
--- a
+++ b
@@ -1084,8 +1084,6 @@
 -- This should fail, but it should produce an error cursor
 SELECT '3.4'::numeric UNION SELECT 'foo';
 ERROR: invalid input syntax for type numeric: "foo"
-LINE 1: SELECT '3.4'::numeric UNION SELECT 'foo';
-^
 --
 -- Test that expression-index constraints can be pushed down through
 -- UNION or UNION ALL
