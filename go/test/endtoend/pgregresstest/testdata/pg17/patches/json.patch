# Known divergence (cosmetic): multigateway rewrites the query before it reaches
# PostgreSQL, so the error-cursor position shifts while the error itself is
# identical. A multi-line JSON literal error points at "LINE 2" instead of "LINE 1".
--- a
+++ b
@@ -306,7 +306,7 @@
 "three":
 true}'::json;
 ERROR: invalid input syntax for type json
-LINE 1: SELECT '{
+LINE 2: "one": 1,
 ^
 DETAIL: Expected JSON value, but found ",".
 CONTEXT: JSON data, line 3: "two":,...
@@ -315,7 +315,7 @@
 "two":"two",
 "averyveryveryveryveryveryveryveryveryverylongfieldname":}'::json;
 ERROR: invalid input syntax for type json
-LINE 1: SELECT '{
+LINE 2: "one": 1,
 ^
 DETAIL: Expected JSON value, but found "}".
 CONTEXT: JSON data, line 4: ...yveryveryveryveryveryveryveryverylongfieldname":}
