# Known divergence pending multi-database support: the isolation harness runs
# against `postgres`, while this upstream spec hardcodes `isolation_regression`.
# The GRANT and teardown therefore fail and VACUUM does not wait. Keep this as an
# output patch rather than rewriting the spec so multi-database support makes the
# patch stop matching and forces the test to be revisited.
--- a
+++ b
@@ -9,13 +9,13 @@
 step grant1:
 GRANT TEMP ON DATABASE isolation_regression TO regress_temp_grantee;
 
-step vac2: VACUUM (FREEZE); <waiting ...>
+ERROR: database "isolation_regression" does not exist
+step vac2: VACUUM (FREEZE);
 step snap3:
 INSERT INTO frozen_witness
 SELECT datfrozenxid FROM pg_database WHERE datname = current_catalog;
 
 step c1: COMMIT;
-step vac2: <... completed>
 step cmp3:
 SELECT 'datfrozenxid retreated'
 FROM pg_database
@@ -26,3 +26,4 @@
 --------
 (0 rows)
 
+teardown failed: ERROR: database "isolation_regression" does not exist
