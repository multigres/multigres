# Known divergence (cosmetic): multigateway rewrites the query before it reaches
# PostgreSQL, so the error-cursor position shifts while the error itself is
# identical. The error cursor points one line earlier ("LINE 5: UNION ALL").
--- a
+++ b
@@ -2177,7 +2177,7 @@
 SELECT i+1 FROM foo WHERE i < 5)
 ) SELECT * FROM foo;
 ERROR: recursive reference to query "foo" must not appear more than once
-LINE 6: SELECT i+1 FROM foo WHERE i < 5)
+LINE 5: UNION ALL
 ^
 WITH RECURSIVE foo(i) AS
 (values (1)
@@ -2188,7 +2188,7 @@
 SELECT i+1 FROM foo WHERE i < 5) AS t
 ) SELECT * FROM foo;
 ERROR: recursive reference to query "foo" must not appear more than once
-LINE 7: SELECT i+1 FROM foo WHERE i < 5) AS t
+LINE 6: UNION ALL
 ^
 WITH RECURSIVE foo(i) AS
 (values (1)
@@ -2198,7 +2198,7 @@
 SELECT i+1 FROM foo WHERE i < 5)
 ) SELECT * FROM foo;
 ERROR: recursive reference to query "foo" must not appear within EXCEPT
-LINE 6: SELECT i+1 FROM foo WHERE i < 5)
+LINE 5: EXCEPT
 ^
 WITH RECURSIVE foo(i) AS
 (values (1)
@@ -2208,7 +2208,7 @@
 SELECT i+1 FROM foo WHERE i < 5)
 ) SELECT * FROM foo;
 ERROR: recursive reference to query "foo" must not appear more than once
-LINE 6: SELECT i+1 FROM foo WHERE i < 5)
+LINE 5: INTERSECT
 ^
 -- Wrong type induced from non-recursive term
 WITH RECURSIVE foo(i) AS
@@ -3626,13 +3626,9 @@
 DROP RULE y_rule ON y;
 -- check that parser lookahead for WITH doesn't cause any odd behavior
 create table foo (with baz); -- fail, WITH is a reserved word
-ERROR: syntax error at or near "with"
-LINE 1: create table foo (with baz);
-^
+ERROR: parse error at position 22: syntax error
 create table foo (with ordinality); -- fail, WITH is a reserved word
-ERROR: syntax error at or near "with"
-LINE 1: create table foo (with ordinality);
-^
+ERROR: parse error at position 22: syntax error
 with ordinality as (select 1 as x) select * from ordinality;
 x
 ---
