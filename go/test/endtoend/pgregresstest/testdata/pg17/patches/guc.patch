 SELECT pg_listening_channels();
 pg_listening_channels
 -----------------------
-foo_event
-(1 row)
+(0 rows)
 
 SELECT name FROM pg_prepared_statements;
 name
 ------
-foo
-(1 row)
+(0 rows)
 
